{
  "name": "eclipsefdn-hugo-solstice-theme",
  "description": "Hugo Solstice theme by the Eclipse Foundation.",
  "main": "webpack.min.js",
  "author": "Christopher Guindon",
  "license": "EPL-2.0",
  "version": "3.1.0",
  "bugs": {
    "url": "https://gitlab.eclipse.org/eclipsefdn/it/webdev/hugo-solstice-theme/-/issues"
  },
  "repository": {
    "type": "git",
    "url": "git@gitlab.eclipse.org:eclipsefdn/it/webdev/hugo-solstice-theme.git"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development webpack --progress --config=node_modules/laravel-mix/setup/webpack.config.js",
    "watch": "cross-env NODE_ENV=development webpack --watch --progress --config=node_modules/laravel-mix/setup/webpack.config.js",
    "hot": "cross-env NODE_ENV=development webpack-dev-server --inline --hot --config=node_modules/laravel-mix/setup/webpack.config.js",
    "production": "cross-env NODE_ENV=production webpack --progress --config=node_modules/laravel-mix/setup/webpack.config.js",
    "fetch_project": "node bin/projects/index.js -l exampleSite/data",
    "build": "npm run production && npm run fetch_project",
    "changeset": "changeset"
  },
  "readmeFilename": "README.md",
  "dependencies": {
    "eclipsefdn-solstice-assets": "0.2.9",
    "json2yaml": "^1.1.0",
    "toml": "^3.0.0"
  },
  "browserslist": "last 5 version, > 0.2%, not dead, IE 11",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "cross-env": "^10.1.0"
  },
  "peerDependencies": {
    "@eclipsefdn/solstice-components": ">=0.7.0 <1.0.0"
  }
}
